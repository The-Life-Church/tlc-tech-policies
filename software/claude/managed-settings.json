{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(curl * | zsh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | zsh)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(brew install:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npx:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(yarn add:*)",
      "Bash(yarn dlx:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(bunx:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(python -m pip install:*)",
      "Bash(python3 -m pip install:*)",
      "Bash(uv pip install:*)",
      "Bash(uvx:*)",
      "Bash(crontab:*)",
      "Bash(launchctl:*)",
      "Bash(systemctl:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(*.pem)",
      "Read(*.key)"
    ]
  },
  "disableBypassPermissionsMode": "disable",
  "companyAnnouncements": [
    "Claude Code has been customized for The Life Church! We've built in instructions to help Claude work better with your creative projects. Curious what's under the hood? github.com/The-Life-Church/tlc-tech-policies/blob/main/software/claude/CLAUDE.md. Questions? IT's got you."
  ],
  "extraKnownMarketplaces": {
    "tlc-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "The-Life-Church/tlc-claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "coding@tlc-claude-plugins": true
  }
}
